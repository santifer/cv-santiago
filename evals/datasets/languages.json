{
  "name": "languages",
  "description": "Verifies language matching for Farid AI.",
  "tests": [
    {
      "id": "spanish-answer",
      "description": "Answers Spanish questions in Spanish.",
      "input": "Resume la experiencia de Farid.",
      "lang": "es",
      "assertions": [
        { "type": "contains_any", "values": ["Farid", "experiencia", "datos", "Intcomex"] }
      ]
    },
    {
      "id": "english-answer",
      "description": "Answers English questions in English.",
      "input": "Summarize Farid's projects.",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Farid", "projects", "wiener", "WHTTP"] }
      ]
    }
  ]
}
