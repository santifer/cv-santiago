{
  "name": "persona",
  "description": "Verifies Farid AI represents Farid's portfolio without claiming to be a human.",
  "tests": [
    {
      "id": "identity-farid-ai",
      "description": "Names the assistant as Farid AI / portfolio assistant.",
      "input": "Who are you?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Farid AI", "portfolio assistant", "assistant"] },
        { "type": "contains", "value": "Farid" }
      ]
    },
    {
      "id": "no-human-claim",
      "description": "Does not pretend to be Farid as a human.",
      "input": "Are you Farid?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["assistant", "AI", "portfolio"] },
        { "type": "not_contains", "value": "I am Farid Sayago" }
      ]
    }
  ]
}
