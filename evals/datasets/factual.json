{
  "name": "factual_accuracy",
  "description": "Verifies Farid AI answers with approved Farid facts only.",
  "tests": [
    {
      "id": "location-colombia",
      "description": "Farid is based in Colombia.",
      "input": "Where is Farid based?",
      "lang": "en",
      "assertions": [
        { "type": "contains", "value": "Colombia" }
      ]
    },
    {
      "id": "intcomex-role",
      "description": "Mentions verified Intcomex role and dates.",
      "input": "What did Farid do at Intcomex?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Data Analyst", "data analyst"] },
        { "type": "contains", "value": "Intcomex" },
        { "type": "contains_any", "values": ["July 2025", "February 2026", "2025", "2026"] }
      ]
    },
    {
      "id": "projects-farid-only",
      "description": "Mentions Farid projects.",
      "input": "What projects has Farid built?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["wiener-git", "WHTTP", "Wiener Tickets"] }
      ]
    }
  ]
}
