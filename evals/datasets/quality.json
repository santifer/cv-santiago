{
  "name": "quality",
  "description": "Verifies useful, concrete Farid answers.",
  "tests": [
    {
      "id": "why-work-with-farid",
      "description": "Gives concrete reasons tied to Farid's work.",
      "input": "Why should a data team work with Farid?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["Python", "SQL", "ETL", "Power BI", "MLOps", "pipelines"] },
        { "type": "not_contains", "value": "generic" }
      ]
    },
    {
      "id": "contact-cta",
      "description": "Contact answer points to public-safe channels.",
      "input": "How can I contact Farid?",
      "lang": "en",
      "assertions": [
        { "type": "contains_any", "values": ["contact form", "LinkedIn", "GitHub", "sayagos.tech"] }
      ]
    }
  ]
}
